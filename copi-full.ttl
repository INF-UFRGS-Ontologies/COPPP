                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000210> ;
                                             rdf:type owl:FunctionalProperty ;
                                             rdfs:domain [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000004>
                                                                                [ rdf:type owl:Class ;
                                                                                  owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000006>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000006> ;
                                             dce:identifier "233-BFO" ;
                                             rdfs:label "occupies spatial region at all times"@en ;
                                             skos:definition "an independent continuant c that is not a spatial region occupies spatial region r at all times =Def for all times t, b exists at t implies (every continuant part of c occupies some continuant part of r at t and no continuant part of c occupies any spatial region that is not a continuant part of r at t)"@en ;
                                             skos:prefLabel "occupies spatial region at all times"@en .


###  http://purl.obolibrary.org/obo/BFO_0000216
