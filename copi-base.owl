     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:iof-core="https://spec.industrialontologies.org/ontology/construct/">
    <owl:Ontology rdf:about="https://www.inf.ufrgs.br/ontologies/copi/copi-base.owl">
        <owl:versionIRI rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/releases/2026-04-27/copi-base.owl"/>
        <dce:type rdf:resource="http://purl.obolibrary.org/obo/IAO_8000001"/>
        <dcterms:description>A domain-core ontology for petroleum production plants developed using the LOT methodology and ODK framework. It provides a foundational semantic layer specializing BFO and IOF-Core, aligning with industrial standards including ISO 15926-4, ISO 14224, CFIHOS, and DEXPI to support interoperability throughout the asset lifecycle.</dcterms:description>
        <dcterms:license rdf:resource="https://opensource.org/license/mit"/>
        <dcterms:title>Core Ontology of Petroleum Installations</dcterms:title>
        <owl:versionInfo>2026-04-27</owl:versionInfo>
    </owl:Ontology>
    


