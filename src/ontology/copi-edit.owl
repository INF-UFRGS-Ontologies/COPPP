Prefix(:=<https://www.inf.ufrgs.br/ontologies/copi.owl#>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(dce:=<http://purl.org/dc/elements/1.1/>)
Prefix(dcterms:=<http://purl.org/dc/terms/>)
Prefix(skos:=<http://www.w3.org/2004/02/skos/core#>)
Prefix(bfo:=<http://purl.obolibrary.org/obo/BFO_>)
Prefix(iof-core:=<https://spec.industrialontologies.org/ontology/construct/>)
Prefix(iof-av:=<https://spec.industrialontologies.org/ontology/annotation/>)
Prefix(copi:=<https://www.inf.ufrgs.br/ontologies/copi/COPI_>)

Ontology(<https://www.inf.ufrgs.br/ontologies/copi.owl>
<https://www.inf.ufrgs.br/ontologies/copi.owl/2026-04-27>

Import(<http://purl.obolibrary.org/obo/bfo/2020/bfo-core.ttl>)
Import(<https://spec.industrialontologies.org/ontology/202502/core/Core/>)

Annotation(dcterms:title "Core Ontology of Petroleum Installations (COPI)"@en)
Annotation(dcterms:title "Ontologia Central de Plantas de Produção de Petróleo (COPI)"@pt)
Annotation(dcterms:description "BFO/IOF-Core conformant ontology of equipment classes for petroleum production plants."@en)
Annotation(dcterms:license <https://opensource.org/license/mit>)
Annotation(owl:versionInfo "2026-04-27")
Annotation(dcterms:contributor "Cauã Antunes")
Annotation(dcterms:contributor "Haroldo Rojas")
Annotation(dcterms:contributor "Rafael Petry")
Annotation(dcterms:contributor "Régis Romeu")
Annotation(dcterms:contributor "Mara Abel")
Annotation(skos:scopeNote "Material artifacts (bfo:material_entity) that (i) are part of a petroleum production plant, and (ii) bear at least one function whose realization involves the transport (e.g. production and injection), processing (separation and other processes), control, monitoring, measurement, containment or offloading of material or energy."@en)
Annotation(skos:scopeNote "Artefatos materiais (bfo:material_entity) que (i) fazem parte de uma planta de produção de petróleo, e (ii) possuem ao menos uma função cuja realização envolve o transporte (p. ex. produção e injeção), processamento (separação e outros processos), controle, monitoramento, medição, contenção ou escoamento de material ou energia."@pt-br)
Annotation(skos:scopeNote "COPI provides high-level equipment categories defined by function to demonstrate the defined-class mechanism. Equipment subtypes are annotated with references to CFIHOS and PCA RDL terms. COPI is not a reference data library; organizations should use CFIHOS, PCA RDL, or ISO 14224 for comprehensive equipment classification."@en)
Annotation(skos:scopeNote "COPI fornece categorias de alto nível de equipamentos definidas por função para demonstrar o mecanismo de classe definida. Os subtipos de equipamentos são anotados com referências aos termos do CFIHOS e do PCA RDL. COPI não é uma biblioteca de dados de referência; organizações devem utilizar o CFIHOS, o PCA RDL ou a ISO 14224 para classificação abrangente de equipamentos."@pt-br)

############################
#   Declarations
############################

Declaration(Class(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001>))
Declaration(Class(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction>))
Declaration(Class(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess>))
Declaration(Class(<https://www.inf.ufrgs.br/ontologies/copi/ValveBody>))
Declaration(Class(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement>))
Declaration(Class(<https://www.inf.ufrgs.br/ontologies/copi/Seat>))
Declaration(AnnotationProperty(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045>))
Declaration(AnnotationProperty(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046>))
Declaration(AnnotationProperty(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047>))
Declaration(AnnotationProperty(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048>))
Declaration(AnnotationProperty(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049>))

############################
#   Annotation Properties
############################

AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045> "iso15926Reference"@en)
AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046> "iso14224Reference"@en)
AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047> "cfihosReference"@en)
AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048> "dexpiReference"@en)
AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049> "poscCaesarReference"@en)

############################
#   Classes
############################

# Class: <https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction> (flow control function)

AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction> "flow control function"@en)
AnnotationAssertion(<https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition> <https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction> "A valve is a material artifact that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction> <https://spec.industrialontologies.org/ontology/construct/DesignedFunction>)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction> ObjectAllValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> <https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess>))

# Class: <https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess> (flow control process)

AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess> "flow control process"@en)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess> <https://spec.industrialontologies.org/ontology/construct/PlannedProcess>)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess> ObjectSomeValuesFrom(<https://spec.industrialontologies.org/ontology/construct/hasInput> <https://www.inf.ufrgs.br/ontologies/copi/FluidPortion>))
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess> ObjectSomeValuesFrom(<https://spec.industrialontologies.org/ontology/construct/hasOutput> <https://www.inf.ufrgs.br/ontologies/copi/FluidPortion>))

# Class: <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> (valve)

AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "valve"@en)
AnnotationAssertion(<https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition> <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "A valve is a material artifact that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en)
AnnotationAssertion(<https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition> <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "Uma válvula é um artefato material que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido."@pt)
AnnotationAssertion(<https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageAxiom> <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams."@en)
AnnotationAssertion(<https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicAxiom> <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "∀x(Valve(x) ↔ MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))"@en)
AnnotationAssertion(<https://spec.industrialontologies.org/ontology/annotation/isPrimitive> <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "true"^^xsd:boolean)
AnnotationAssertion(<https://spec.industrialontologies.org/ontology/annotation/primitiveRationale> <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "Might be too restrictive to define as sufficient being a material artifact and having a flow control function."@en)
AnnotationAssertion(skos:definition <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "[ISO 15926-4] A <VALVE> is a <FLUID REGULATOR> that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream"@en)
AnnotationAssertion(skos:definition <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "[CFIHOS] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en)
AnnotationAssertion(skos:definition <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "[OnePetro] Any of several valves:  plug, gate, butterfly, needle, etc., used in oil field operations."@en)
AnnotationAssertion(skos:definition <https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> "[POSC Caesar] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> ObjectSomeValuesFrom(<https://spec.industrialontologies.org/ontology/construct/hasFunction> <https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction>))
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> ObjectSomeValuesFrom(<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> <https://www.inf.ufrgs.br/ontologies/copi/ValveBody>))
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> ObjectSomeValuesFrom(<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> <https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement>))
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> ObjectSomeValuesFrom(<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> <https://www.inf.ufrgs.br/ontologies/copi/Seat>))
AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/ValveBody> "valve body"@en)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/ValveBody> <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>)
AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement> "flow control element"@en)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement> <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>)
AnnotationAssertion(rdfs:label <https://www.inf.ufrgs.br/ontologies/copi/Seat> "seat"@en)
SubClassOf(<https://www.inf.ufrgs.br/ontologies/copi/Seat> <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>)
DisjointClasses(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> <https://www.inf.ufrgs.br/ontologies/copi/Pump>)
DisjointClasses(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> <https://www.inf.ufrgs.br/ontologies/copi/Compressor>)
DisjointClasses(<https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001> <https://www.inf.ufrgs.br/ontologies/copi/Turbine>)

)
