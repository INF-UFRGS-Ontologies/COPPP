<https://www.inf.ufrgs.br/ontologies/copi/copi-base.ttl> rdf:type owl:Ontology ;
                                                          owl:versionIRI <https://www.inf.ufrgs.br/ontologies/copi/releases/2026-04-27/copi-base.ttl> ;
                                                          dce:type <http://purl.obolibrary.org/obo/IAO_8000001> ;
                                                          dcterms:description "A domain-core ontology for petroleum production plants developed using the LOT methodology and ODK framework. It provides a foundational semantic layer specializing BFO and IOF-Core, aligning with industrial standards including ISO 15926-4, ISO 14224, CFIHOS, and DEXPI to support interoperability throughout the asset lifecycle." ;
                                                          dcterms:license <https://opensource.org/license/mit> ;
                                                          dcterms:title "Core Ontology of Petroleum Installations" ;
                                                          owl:versionInfo "2026-04-27" .

