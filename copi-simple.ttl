###  https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicAxiom
annotation:firstOrderLogicAxiom rdf:type owl:AnnotationProperty ;
                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                rdfs:label "first-order logic axiom"@en-us ;
                                skos:definition "logic axiom annotation written in first order logic"@en-us ;
                                annotation:usageNote "First-order logic axioms MAY be provided if the term is primitive ('is primitive' is true ) or non-primitive. A construct MAY include more than one first-order logic axiom annotation."@en-us .


###  https://spec.industrialontologies.org/ontology/annotation/isPrimitive
annotation:isPrimitive rdf:type owl:AnnotationProperty ;
                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                       rdfs:label "is primitive"@en-us ;
                       skos:definition "boolean flag indicating that necessary and sufficient conditions are not provided"@en-us ;
                       annotation:usageNote "'is primitive' must be present if the term does not have necessary and sufficient conditions and the value of the annotation must be set to true. When 'is primitive' is set to true, a value for a 'primitive rationale' annotation must also be provided."@en-us .


###  https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition
annotation:naturalLanguageDefinition rdf:type owl:AnnotationProperty ;
                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                     rdfs:label "natural language definition"@en-us ;
                                     skos:definition "definition written in plain text for human understanding"@en-us ;
                                     annotation:usageNote """This annotation is Required for each non-primitive or non-axiomatic class of an IOF (OWL or Common Logic) ontology. 
 - It is optional for primitive (aka axiomatic) classes since such the Elucidation annotation is required and will satisfy the role of a natural language definition.
 - It is optional, but recommended, for relations when the intent of a relation may be misunderstood.
 - There should be at most one.
 - This natural language definition should be subject matter expert friendly and consistent with any formal definition or elucidation.
 - Natural language definitions should use class and relation names with following caveats:
 a) Relations – For those relations whose label (i.e. local identifier) consist of multiple terms hyphenate the terms of the label: e.g. 'hasPlan' would be written as 'has-plan'
 b) Classes – For classes whose label has multiple distinct terms, e.g, ManufacturingOperationSpecification, separate the terms but bound them with apostrophe marks: 'Manufacturing Operation Specification'."""@en-us ;
                                     rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/annotation/primitiveRationale
annotation:primitiveRationale rdf:type owl:AnnotationProperty ;
                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                              rdfs:label "primitive rationale"@en-us ;
                              skos:definition "reason why necessary and sufficient conditions could not be provided"@en-us ;
                              annotation:usageNote "When 'is primitive' is set to true, a value for 'primitive rationale' must be provided. The rationale should indicate what is missing if additional work is required to define necessary and sufficient conditions."@en-us .


###  https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageAxiom
annotation:semiFormalNaturalLanguageAxiom rdf:type owl:AnnotationProperty ;
                                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                          rdfs:label "semi-formal natural language axiom"@en-us ;
                                          skos:definition "logic axiom expressed in natural language"@en-us ;
                                          annotation:usageNote "Semi-formal natural language axioms MAY be provided if the term is primitive (is primitive is true). A construct MAY include more than one semi-formal natural language axiom annotation."@en-us .


###  https://spec.industrialontologies.org/ontology/annotation/synonym
annotation:synonym rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/usageNote
annotation:usageNote rdf:type owl:AnnotationProperty .


