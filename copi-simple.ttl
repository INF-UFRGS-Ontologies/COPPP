#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000054
<http://purl.obolibrary.org/obo/BFO_0000054> rdf:type owl:ObjectProperty ;
                                             dc:identifier "206-BFO" ;
                                             rdfs:label "has realization"@en ;
                                             skos:altLabel "realized in"@en ;
                                             skos:definition "b has realization c =Def c realizes b"@en ;
                                             skos:example "As for realizes"@en ;
                                             skos:prefLabel "has realization"@en ;
                                             annotation:synonym "realized in"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> rdf:type owl:ObjectProperty ,
                                                                                               owl:TransitiveProperty ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "has component part at all times"@en-us ;
                                                                                      skos:example "car has component part a chasy; a bioractor has component part a stainless steel vessel"@en-us ;
                                                                                      annotation:firstOrderLogicAxiom "hasComponentPartAtAllTimes(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ hasProperContinuantPartAtAllTimes(x,y)" ;
                                                                                      annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it has as a proper part at all times it exists"@en-us ;
                                                                                      annotation:semiFormalNaturalLanguageAxiom "x has component part at all times y holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x 'has proper continuant part at all times' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasFunction
<https://spec.industrialontologies.org/ontology/construct/hasFunction> rdf:type owl:ObjectProperty ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                       rdfs:label "has function"@en-us ;
                                                                       skos:example "this enzyme has function this catalysis function (more colloquially: this enzyme has this catalysis function)"@en-us ;
                                                                       annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000085" ;
                                                                       annotation:explanatoryNote "A bearer can have many functions, and its functions can exist for different periods of time, but none of its functions can exist when the bearer does not exist. A function need not be realized at all the times that the function exists."@en-us ;
                                                                       annotation:firstOrderLogicAxiom "hasFunction(x,y) → IndependentContinuant(x) ∧ Function(y) ∧ bearerOf(x,y)" ;
                                                                       annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a function, in which the function specifically depends on the bearer for its existence"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageAxiom "x has function y holds when x is a 'independent continuant' and y is a 'function' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasInput
<https://spec.industrialontologies.org/ontology/construct/hasInput> rdf:type owl:ObjectProperty ;
                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                    rdfs:label "has input"@en-us ;
                                                                    skos:example "machine learning execution process has input a dataset;fermentation process has input growth medium; additive manufacturing process has input metal powder;"@en-us ;
                                                                    annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                    annotation:naturalLanguageDefinition "relation from a process to someone or something physical or digital (continuant) that is a necessary precondition for the process to start"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasOutput
<https://spec.industrialontologies.org/ontology/construct/hasOutput> rdf:type owl:ObjectProperty ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "has output"@en-us ;
                                                                     skos:example "chemical manufacturing process has output a wastestream; toluene manufacturing process has output a certain quantity of toluene; car manufacturing process has output a car"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                     annotation:explanatoryNote "By introducing the condition that it must exist at the end of the process materials that only transitively exist during the process (e.g., reaction intermediary) are excluded from being considered the output." ;
                                                                     annotation:naturalLanguageDefinition "relation from a process to someone or something physical or digital (continuant) that participates in the process such that it is generated or modified during the process, and that it exists at the end of the process"@en-us .


#################################################################
#    Classes
#################################################################

###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001
copi:COPI_0000001 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlowControlElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Seat
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ValveBody
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FlowControlFunction
                                  ] ;
                  owl:disjointWith copi:Compressor ,
                                   copi:Pump ,
                                   copi:Turbine ;
                  rdfs:label "valve"@en ;
                  skos:definition "[CFIHOS] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en ,
                                  "[ISO 15926-4] A <VALVE> is a <FLUID REGULATOR> that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream"@en ,
                                  "[OnePetro] Any of several valves:  plug, gate, butterfly, needle, etc., used in oil field operations."@en ,
                                  "[POSC Caesar] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Valve(x) ↔ MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A valve is a material artifact that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en ,
                                                       "Uma válvula é um artefato material que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido."@pt ;
                  annotation:primitiveRationale "Might be too restrictive to define as sufficient being a material artifact and having a flow control function."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Compressor
copi:Compressor rdf:type owl:Class .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement
copi:FlowControlElement rdf:type owl:Class ;
                        rdfs:label "flow control element"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction
copi:FlowControlFunction rdf:type owl:Class ;
                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:allValuesFrom copi:FlowControlProcess
                                         ] ;
                         rdfs:label "flow control function"@en ;
                         annotation:naturalLanguageDefinition "A valve is a material artifact that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess
copi:FlowControlProcess rdf:type owl:Class ;
                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasInput> ;
                                          owl:someValuesFrom copi:FluidPortion
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasOutput> ;
                                          owl:someValuesFrom copi:FluidPortion
                                        ] ;
                        rdfs:label "flow control process"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FluidPortion
copi:FluidPortion rdf:type owl:Class .


###  https://www.inf.ufrgs.br/ontologies/copi/Pump
copi:Pump rdf:type owl:Class .


###  https://www.inf.ufrgs.br/ontologies/copi/Seat
copi:Seat rdf:type owl:Class ;
          rdfs:label "seat"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Turbine
copi:Turbine rdf:type owl:Class .


###  https://www.inf.ufrgs.br/ontologies/copi/ValveBody
copi:ValveBody rdf:type owl:Class ;
               rdfs:label "valve body"@en .


